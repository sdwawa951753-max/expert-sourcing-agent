# Copy to .env and fill in. All are optional — the tool degrades gracefully.

# Claude for profiles + outreach drafting. Without it, offline templates are used.
ANTHROPIC_API_KEY=sk-ant-...

# Web search for talks/news/contact enrichment. Pick ONE (or none).
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-...
# SERPER_API_KEY=...

# Recommended: your email joins OpenAlex's faster "polite pool" (no key needed).
OPENALEX_MAILTO=you@example.com
